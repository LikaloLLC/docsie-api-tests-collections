# Docsie Partner API Test Configuration
# Copy to .env and fill in your values

# Required: API key for the test organization
DOCSIE_API_KEY=your_api_key_here

# Base URL of the Docsie instance to test against
DOCSIE_BASE_URL=https://staging.docsie.io

# Optional: a public video URL for video-to-docs tests
# Falls back to a short sample if not set
TEST_VIDEO_URL=https://www.youtube.com/watch?v=dQw4w9WgXcQ

# Optional: pre-existing IDs to skip creation steps
# TEST_WORKSPACE_ID=
# TEST_DOCUMENTATION_ID=
# TEST_BOOK_ID=
